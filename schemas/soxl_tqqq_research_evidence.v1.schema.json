{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantstrategylab.github.io/schemas/soxl_tqqq_research_evidence.v1.schema.json",
  "title": "SOXL/TQQQ research evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "profile", "run_id", "code_sha", "config_sha256", "plugin_sha256", "data_sha256",
    "data_revision", "calendar", "timezone", "execution_timing", "cost_model_id", "random_seed",
    "as_of", "generated_at", "artifacts"
  ],
  "properties": {
    "schema": {"const": "soxl_tqqq_research_evidence.v1"},
    "profile": {"enum": ["soxl_soxx_trend_income", "tqqq_growth_income"]},
    "run_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
    "code_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "config_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "plugin_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "data_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "data_revision": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
    "calendar": {"enum": ["XNYS", "NYSE"]},
    "timezone": {"const": "America/New_York"},
    "execution_timing": {
      "type": "string",
      "pattern": "^(next_open|next_close|scheduled_vwap|other:[a-z0-9][a-z0-9._-]{1,63})$"
    },
    "cost_model_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
    "random_seed": {"type": "integer", "minimum": 0},
    "as_of": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "champion_identity.json", "prices.csv", "data_quality.json", "daily_returns.csv", "targets.csv",
        "trades.csv", "costs.csv", "metrics.json", "walk_forward.json", "trial_ledger.jsonl", "robustness.json",
        "risk_sleeve.json", "strategy_performance.v2.json", "checksums.sha256"
      ],
      "properties": {
        "champion_identity.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "prices.csv": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "data_quality.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "daily_returns.csv": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "targets.csv": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "trades.csv": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "costs.csv": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "metrics.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "walk_forward.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "trial_ledger.jsonl": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "robustness.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "risk_sleeve.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "strategy_performance.v2.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "checksums.sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
